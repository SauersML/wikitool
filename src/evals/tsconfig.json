{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["bun-types"],
		"noEmit": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true
	},
	"include": ["**/*.ts", "../tests/**/*.ts"],
	"exclude": ["node_modules"]
}
